+// ------------------------------------------------------------------
+// Portable token scanner — replaces sscanf %[RANGEBASE] scansets.
+//
+// The old code used sscanf with a very long %[...] character class
+// built from raw hex bytes.  POSIX leaves the interpretation of '-'
+// inside scansets implementation-defined when it is not first or last,
+// and the RANGEBASE macros placed '\x2d' ('-') between '\x2c' and
+// '\x30', causing some C libraries (notably Apple libc on macOS 15
+// under Virtualization.framework) to treat it as a range, silently
+// changing the accepted character set.
+//
+// This manual scanner accepts exactly the characters that the old
+// scansets were *intended* to accept, without depending on sscanf at
+// all.
+// ------------------------------------------------------------------
+
+// Returns true if 'c' is a valid token character for method patterns.
+// Excluded: '\0', ' ', '\t', '(', ')', '[', ']', 0xf0-0xff.
+// '/' is only allowed when allow_slash == true (class names).
+// '.' is already converted to ' ' by canonicalize() before we get here.
+static inline bool is_token_char(unsigned char c, bool allow_slash) {
+  if (c == '\0' || c == ' ' || c == '\t')   return false;
+  if (c == '(' || c == ')')                 return false;
+  if (c == '[' || c == ']')                 return false;
+  if (c >= 0xf0)                            return false;
+#ifdef _WINDOWS
+  if (!isascii(c))                          return false;
+#endif
+  if (c == '/' && !allow_slash)             return false;
+  return true;
+}
+
+// Scan a single token from 'line' into 'buf' (max 'maxlen' chars).
+// Returns the number of characters consumed, or 0 if no token found.
+static int scan_token(const char* line, char* buf, int maxlen, bool allow_slash) {
+  int i = 0;
+  while (i < maxlen && is_token_char((unsigned char)line[i], allow_slash)) {
+    buf[i] = line[i];
+    i++;
+  }
+  buf[i] = '\0';
+  return i;
+}
+
+// Scan a signature from 'line' into 'buf' (max 'maxlen' chars).
+// Accepts the same characters as tokens plus '[', ']', ')', ';', '/'.
+static int scan_signature(const char* line, char* buf, int maxlen) {
+  int i = 0;
+  while (i < maxlen && line[i] != '\0') {
+    unsigned char c = (unsigned char)line[i];
+    if (c == ' ' || c == '\t' || c == '(' || c >= 0xf0) break;
+    buf[i] = line[i];
+    i++;
+  }
+  buf[i] = '\0';
+  return i;
+}
